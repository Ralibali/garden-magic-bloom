{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/guider",
      "destination": "/blogg",
      "permanent": true
    },
    {
      "source": "/guider/:slug",
      "destination": "/blogg/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
